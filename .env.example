# ── Discord ─────────────────────────────────────────────
# Bot token из Discord Developer Portal → Application → Bot → Reset Token
DISCORD_TOKEN=
# Application ID (он же Client ID) из вкладки General Information
DISCORD_CLIENT_ID=
# ID твоего Discord-сервера (вкл. Developer Mode → ПКМ по серверу → Copy Server ID).
# При COMMAND_SCOPE=guild команды регистрируются на этой гильдии — появляются мгновенно.
DISCORD_GUILD_ID=
# guild (по умолчанию) — команды на DISCORD_GUILD_ID, мгновенно.
# global — команды на всех серверах бота, но появляются до ~1 часа.
COMMAND_SCOPE=guild

# ── Jellyfin (Фаза 1) ───────────────────────────────────
# Базовый URL сервера, без слеша на конце. Напр.: https://jellyfin.example.com
JELLYFIN_URL=
# API-ключ: Jellyfin → Dashboard → API Keys → New
JELLYFIN_API_KEY=
# Публичный URL Jellyfin (для обложек в Discord-панели — Discord тянет картинку
# со своих серверов, поэтому локальный 127.0.0.1 не подойдёт). Напр. https://starald.ru
JELLYFIN_PUBLIC_URL=

# ── Jellyfin (Фаза 2, опционально) ──────────────────────
# Нужны только для каста из веб-интерфейса Jellyfin (Фаза 2). Для Фазы 1 оставь пустыми.
JELLYFIN_USERNAME=
JELLYFIN_PASSWORD=

# ── Веб-панель (сайт ds.starald.ru) ─────────────────────
# true (по умолчанию) — поднимать веб-панель. false — только Discord-бот.
PANEL_ENABLED=true
# Порт панели на localhost (nginx проксирует сюда). По умолчанию 8730.
PANEL_PORT=8730
# Логин и пароль для входа в панель. БЕЗ PANEL_PASSWORD публичная панель не поднимется.
PANEL_USERNAME=admin
PANEL_PASSWORD=
# Отдельный пароль для раздела «Администрирование» (сертификат/логи).
# Если пусто — используется PANEL_PASSWORD. Задай свой для отдельного доступа.
ADMIN_PASSWORD=
# Секрет для подписи cookie-сессии (любая длинная случайная строка).
# Если пусто — сгенерится при старте, но сессии будут сбрасываться при перезапуске.
SESSION_SECRET=
# true (по умолчанию) — secure-cookie (нужно за HTTPS/nginx).
# Поставь false ТОЛЬКО для локального теста по http://localhost:PANEL_PORT.
PANEL_SECURE_COOKIE=true

# ── YouTube (через yt-dlp) ──────────────────────────────
# Путь к cookies.txt (экспорт из браузера, залогиненного в YouTube) — нужен,
# чтобы обойти анти-бот проверку YouTube. По умолчанию youtube-cookies.txt в корне.
YT_COOKIES=youtube-cookies.txt
# Прокси для yt-dlp (опц.), напр. socks5://127.0.0.1:1080 — если IP флагнут.
YT_PROXY=
# Ключ YouTube Data API v3 — быстрый поиск (~0.6с, не зависит от IP).
# Google Cloud Console → APIs → включить "YouTube Data API v3" → Credentials → API key.
# Без ключа поиск идёт через yt-dlp (медленнее). Воспроизведение всегда через yt-dlp+куки.
YOUTUBE_API_KEY=

# ── Прокси для ВК (опционально) ─────────────────────────
# Если прямой путь до CDN ВК не работает (DPI/ISP), гоняем API и стрим ВК через
# прокси — тогда ВК играет в режиме PROXY (без полного VPN-туннеля).
# Обычно тот же прокси, что у YouTube. Пусто = напрямую.
VK_PROXY=
# Прокси для Яндекса. ВНИМАНИЕ: Яндекс.Музыка геоблочит иностранные выходы (451),
# поэтому иностранный прокси НЕ подойдёт — оставляй пустым (нужен РФ-маршрут/прямой).
YANDEX_PROXY=

# ── Яндекс.Музыка ───────────────────────────────────────
# OAuth-токен аккаунта (для стрима нужна подписка Плюс).
YANDEX_MUSIC_TOKEN=

# ── ВКонтакте (аудио соцсети) ───────────────────────────
# Аудио ВК отдаётся только токену официального клиента (password-grant).
# Получи токен скриптом:  npm run vk-token  (или "Получить токен ВК.bat") —
# он сам впишет сюда VK_TOKEN и VK_UA. Токены с vkhost.github.io аудио НЕ дают.
VK_TOKEN=
# User-Agent клиента, которым добыт токен (audio API требует совпадения).
# Заполняется скриптом автоматически; вручную трогать не нужно.
VK_UA=

# ── Поведение (опционально) ─────────────────────────────
# Через сколько мс простоя (пустая очередь / нет слушателей) бот выходит из голосового канала.
IDLE_TIMEOUT_MS=300000
# debug | info | warn | error
LOG_LEVEL=info
