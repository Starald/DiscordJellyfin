{
  "name": "jellyfin-discord-bot",
  "version": "0.1.0",
  "description": "Self-hosted Discord bot that plays whole music albums from a Jellyfin server in a voice channel.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc && node scripts/copy-assets.mjs",
    "typecheck": "tsc --noEmit",
    "jellyfin:smoke": "tsx src/scripts/jellyfin-smoke.ts",
    "vk-token": "node scripts/vk-token.mjs"
  },
  "dependencies": {
    "@discordjs/voice": "0.19.2",
    "@snazzah/davey": "^0.1.11",
    "cookie-session": "^2.1.1",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "libsodium-wrappers": "^0.7.15",
    "opusscript": "^0.0.8",
    "prism-media": "^1.3.5"
  },
  "devDependencies": {
    "@types/cookie-session": "^2.0.49",
    "@types/express": "^5.0.6",
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
